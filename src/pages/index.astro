---
import BaseLayout from "../layouts/BaseLayout.astro";

const links = [
  {
    label: "Email",
    href: "mailto:hi@mikaelkalkmann.com",
    description: "hi@mikaelkalkmann.com",
    external: false,
  },
  {
    label: "LinkedIn",
    href: "https://www.linkedin.com/in/mikael-kalkmann/",
    description: "Professional profile and experience.",
    external: true,
  },
  {
    label: "GitHub",
    href: "https://github.com/mikaelkkn",
    description: "Code and open-source projects.",
    external: true,
  },
];
---

<BaseLayout title="Mikael Kalkmann">
  <div class="root">
    <header>
      <a href="/" class="name">Mikael Kalkmann</a>
      <span class="subtitle">Software Engineer</span>
    </header>

    <main>
      <section>
        <span class="label">About</span>
        <p class="muted">
          I still remember the sense of fascination the first time I
          compiled source code. Today, I transform lines of code into
          applications that help businesses and people grow every day.
        </p>
      </section>

      <section class="section">
        <span class="label">Today</span>
        <p class="muted">
          I'm a tech lead at CWI Software, where I guide the technical direction
          of our work and help the people around me do their best.
        </p>
      </section>

      <section class="section group">
        <span class="label">Elsewhere</span>
        <div class="list">
          {
            links.map((link) => (
              <a
                class="row"
                href={link.href}
                {...(link.external
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                <span>{link.label}</span>
                <span class="muted">{link.description}</span>
              </a>
            ))
          }
        </div>
      </section>
    </main>
  </div>
</BaseLayout>

<style>
  .root {
    max-width: 692px;
    margin: 0 auto;
    padding: 48px 24px;
  }

  @media (min-width: 640px) {
    .root {
      padding: 80px 24px;
    }
  }

  @media (min-width: 768px) {
    .root {
      padding: 64px 24px;
    }
  }

  /* ---- header ---- */
  header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 80px;
  }

  .name {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
  }

  .subtitle {
    font-size: 15px;
    font-weight: 500;
    line-height: 1;
    color: var(--text-secondary);
  }

  /* ---- section labels ---- */
  .label {
    display: block;
    font-weight: 500;
    color: var(--text);
    margin-bottom: 20px;
  }

  @media (min-width: 640px) {
    .label {
      margin-bottom: 16px;
    }
  }

  /* ---- text ---- */
  .muted {
    color: var(--text-secondary);
  }

  .mt {
    margin-top: 16px;
  }

  /* ---- section spacing ---- */
  .section {
    margin-top: 64px;
  }

  @media (min-width: 640px) {
    .section {
      margin-top: 80px;
    }
  }

  /* offsets the row padding so the group aligns with the label */
  .group {
    margin-bottom: -12px;
  }

  .list {
    display: flex;
    flex-direction: column;
    gap: 28px;
  }

  @media (min-width: 640px) {
    .list {
      gap: 16px;
    }
  }

  .row {
    display: flex;
    flex-direction: column;
    margin: 0 -12px;
    padding: 0 12px;
    border-radius: 6px;
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .row:hover {
    background-color: var(--hover-bg);
  }

  @media (min-width: 640px) {
    .row {
      padding: 12px;
    }
  }
</style>
